{
  "name": "autotriage-extension",
  "displayName": "AutoTriage Extension",
  "description": "Tracks coding activity and groups edits into development sessions.",
  "version": "0.0.1",
  "publisher": "shriya",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:autotriage.flushSession"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autotriage.flushSession",
        "title": "AutoTriage: Flush Session"
      }
    ]
  }
}